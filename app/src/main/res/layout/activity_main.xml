<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <!-- 3D SceneView fills the screen above the bottom panel -->
    <io.github.sceneview.SceneView
        android:id="@+id/sceneView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom panel: color picker + solve button + solution display -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#2D2D44"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Solution display (hidden until solved) -->
        <HorizontalScrollView
            android:id="@+id/solutionScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/tvSolution"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFD700"
                android:textSize="15sp"
                android:fontFamily="monospace" />
        </HorizontalScrollView>

        <!-- Color picker row + Solve button side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <!-- Color buttons -->
            <LinearLayout
                android:id="@+id/colorButtonRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <FrameLayout android:id="@+id/btnWhite"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/color_button_white"
                    android:clickable="true" android:focusable="true" />
                <FrameLayout android:id="@+id/btnYellow"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/color_button_yellow"
                    android:clickable="true" android:focusable="true" />
                <FrameLayout android:id="@+id/btnRed"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/color_button_red"
                    android:clickable="true" android:focusable="true" />
                <FrameLayout android:id="@+id/btnOrange"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/color_button_orange"
                    android:clickable="true" android:focusable="true" />
                <FrameLayout android:id="@+id/btnBlue"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/color_button_blue"
                    android:clickable="true" android:focusable="true" />
                <FrameLayout android:id="@+id/btnGreen"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/color_button_green"
                    android:clickable="true" android:focusable="true" />
                <FrameLayout android:id="@+id/btnGray"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/color_button_gray"
                    android:clickable="true" android:focusable="true" />
            </LinearLayout>

            <!-- Solve button -->
            <Button
                android:id="@+id/btnSolve"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:text="求解"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E65100"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <!-- Selected color + status label -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="已選: 白色  ─  拖拽旋轉，點擊貼紙上色"
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingTop="4dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
